[Unit]
Description=NHI Map - Non-Human Identity Inventory
After=postgresql.service network.target
Requires=postgresql.service

[Service]
Type=simple
User=zach
WorkingDirectory=/home/zach/nhi-map/backend
Environment=PATH=/home/zach/nhi-map/backend/venv/bin:/usr/local/bin:/usr/bin:/bin
ExecStart=/home/zach/nhi-map/backend/venv/bin/uvicorn main:app --host 0.0.0.0 --port 8000
Restart=on-failure
RestartSec=5

[Install]
WantedBy=multi-user.target
